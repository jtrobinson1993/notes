{
  "name": "accord",
  "private": true,
  "version": "0.5.6",
  "type": "module",
  "workspaces": [
    "shared",
    "server",
    "web"
  ],
  "scripts": {
    "build": "npm run build -w shared && npm run build -w server && npm run build -w web",
    "typecheck": "npm run build -w shared && npm run typecheck -w server && npm run typecheck -w web",
    "dev:server": "npm run dev -w server",
    "dev:web": "npm run dev -w web",
    "start": "node server/dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium webkit"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "vitest": "^4.1.8",
    "ws": "^8.18.0"
  }
}
