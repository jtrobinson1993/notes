{
  "name": "notes",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "shared",
    "server",
    "web"
  ],
  "scripts": {
    "build": "npm run build -w shared && npm run build -w server && npm run build -w web",
    "typecheck": "npm run typecheck -w server && npm run typecheck -w web",
    "dev:server": "npm run dev -w server",
    "dev:web": "npm run dev -w web",
    "start": "node server/dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4"
  }
}
