# Config for self-hosted "notes" — copy to `.env` (gitignored): `cp .env.example .env`.
# docker compose reads this file for both image/proxy config (below) and the
# secrets it injects into the container. See DEPLOY.md for the full walkthrough.

# --- Core deploy config (read by docker compose / Caddy) --------------------

# The exact public URL you open the app at. Passkeys are bound to it, and Caddy
# provisions the HTTPS certificate for this hostname. REQUIRED for a real deploy.
APP_ORIGIN=https://notes.yourdomain.com

# Which published image to run. `latest` tracks the newest release; pin a version
# (e.g. 0.2.0 — unprefixed; a `v0.2.0` git tag publishes image `0.2.0`) to
# control upgrades and to roll back (set it and `up -d`).
NOTES_TAG=latest

# --- Integration keys / secrets (injected into the container) ---------------

# KLIPY GIF search (https://klipy.com). Free tier; used by the server-side
# /api/gifs proxy so the key never reaches the browser. Leave unset to disable
# GIF search.
KLIPY_API_KEY=

# Web Push (PWA background "new message" notifications). OPTIONAL — leave all
# three unset and the server generates a VAPID keypair on first boot and
# persists it to DATA_DIR/vapid.json. Set these only to pin a keypair explicitly
# (e.g. shared across instances); `npx web-push generate-vapid-keys` prints a
# pair. Push requires the app to be served over HTTPS.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@notes.yourdomain.com

# v6 voice (mediasoup SFU). Audio is end-to-end encrypted and relayed by the
# server, so clients connect directly to it for media (RTP over UDP). In a real
# deployment set VOICE_ANNOUNCED_IP to the host's PUBLIC/LAN IP that clients can
# reach, and publish + forward the RTC port range (defaults below). Left unset,
# voice works only locally (announced as 127.0.0.1).
# VOICE_ANNOUNCED_IP=203.0.113.10
# VOICE_LISTEN_IP=0.0.0.0
# VOICE_RTC_MIN_PORT=40000
# VOICE_RTC_MAX_PORT=40100
