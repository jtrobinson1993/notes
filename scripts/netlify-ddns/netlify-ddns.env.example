# Copy to /etc/netlify-ddns.env on the server and lock it down:
#   sudo install -m 600 netlify-ddns.env.example /etc/netlify-ddns.env
# then edit the values below.
#
# SECURITY: a Netlify personal access token is ACCOUNT-WIDE (there is no
# DNS-only scope), so it can also touch your other sites. Keep this file
# root-only (mode 600) and never commit the real token.

# Netlify → avatar → User settings → Applications → Personal access tokens
NETLIFY_TOKEN=nfp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The domain (zone) you manage in Netlify DNS, and the subdomain to keep updated.
DOMAIN=yourdomain.com
RECORD=notes.yourdomain.com
